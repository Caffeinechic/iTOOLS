# Copy to .env and adjust for your setup.

# Docker Mongo (docker compose up mongo -d)
MONGO_URI=mongodb://itoolsmongo:itoolsmongopassword@localhost:27017/itools?authSource=admin

# Local Mongo without auth
# MONGO_URI=mongodb://localhost:27017/itools

JWT_SECRET=supersecretjwtkeyforitools
PORT=4000

# Shared password for all seeded EC accounts (login)
DEFAULT_PASSWORD=admin123
