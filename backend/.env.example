# Bootstrap-only — set these in your host environment or Docker secrets.
# Do NOT commit real values. JWT, passwords, and API keys are managed via
# Dashboard → System Settings (encrypted in MongoDB).

# Required: Fernet key for encrypting settings at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=

# MongoDB connection (required to reach the database)
MONGO_URI=mongodb://itoolsmongo:itoolsmongopassword@localhost:27018/itools?authSource=admin

# Optional server config
PORT=4000
NODE_ENV=development
